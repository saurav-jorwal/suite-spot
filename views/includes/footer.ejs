            <div style="color:#717171; font-size:0.85rem;"><%- d.type %></div>
          </a>
        <% }) %>
      </div>
    </div>

    <div id="tab-mountains" class="tab-content" style="display:none;">
      <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:1.2rem 1.5rem;">
        <% [
          {city:"San Bernardino",type:"Apartment rentals"},{city:"Bristol",type:"Holiday rentals"},{city:"Red Lodge",type:"Cabin rentals"},
          {city:"Alpharetta",type:"Holiday rentals"},{city:"Guatemala City",type:"Flat rentals"},{city:"Visalia",type:"Cabin rentals"},
          {city:"Tucson",type:"Apartment rentals"},{city:"Idaho Springs",type:"Pet-friendly rentals"},{city:"Glendale",type:"Holiday rentals"},
          {city:"Reno",type:"Pet-friendly rentals"},{city:"Ozark",type:"Pet-friendly rentals"},{city:"San Mateo",type:"Cabin rentals"},
          {city:"Bentonville",type:"Pet-friendly rentals"},{city:"Anacortes",type:"Monthly Rentals"},{city:"Lawrenceville",type:"Cabin rentals"},
