<footer style="background:#fff; border-top:1px solid #ebebeb; font-family:'DM Sans',sans-serif; color:#222;">

  <!-- Inspiration section -->
  <div style="padding:3rem 5rem; border-bottom:1px solid #ebebeb;">
    <p style="font-size:1.3rem; font-weight:700; margin:0 0 1.5rem 0;">Inspiration for future getaways</p>

    <!-- Tabs -->
    <div style="display:flex; gap:2rem; border-bottom:1px solid #ebebeb; margin-bottom:2rem;">
      <span class="footer-tab" data-tab="popular"   style="padding-bottom:0.7rem; font-weight:600; font-size:0.95rem; cursor:pointer; border-bottom:2px solid #222; color:#222;">Popular</span>
      <span class="footer-tab" data-tab="arts"      style="padding-bottom:0.7rem; color:#717171; font-size:0.95rem; cursor:pointer;">Arts &amp; culture</span>
      <span class="footer-tab" data-tab="beach"     style="padding-bottom:0.7rem; color:#717171; font-size:0.95rem; cursor:pointer;">Beach</span>
      <span class="footer-tab" data-tab="mountains" style="padding-bottom:0.7rem; color:#717171; font-size:0.95rem; cursor:pointer;">Mountains</span>
      <span class="footer-tab" data-tab="outdoors"  style="padding-bottom:0.7rem; color:#717171; font-size:0.95rem; cursor:pointer;">Outdoors</span>
      <span class="footer-tab" data-tab="things"    style="padding-bottom:0.7rem; color:#717171; font-size:0.95rem; cursor:pointer;">Things to do</span>
    </div>

    <div id="tab-popular" class="tab-content">
      <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:1.2rem 1.5rem;">
        <% [
          {city:"Madrid",type:"Apartment rentals"},{city:"Tokyo",type:"Flat rentals"},{city:"Washington",type:"House rentals"},
          {city:"Wilmington",type:"Flat rentals"},{city:"Key West",type:"Monthly Rentals"},{city:"Kauai",type:"House rentals"},
          {city:"St. Petersburg",type:"House rentals"},{city:"Galveston",type:"Monthly Rentals"},{city:"Cleveland",type:"House rentals"},
          {city:"Tampa",type:"Villa rentals"},{city:"Brooklyn",type:"Flat rentals"},{city:"Clearwater",type:"Villa rentals"},
          {city:"Outer Banks",type:"House rentals"},{city:"Las Vegas",type:"Holiday rentals"},{city:"Cape Cod",type:"Flat rentals"},
          {city:"Dublin",type:"Flat rentals"},{city:"Milan",type:"Villa rentals"}
        ].forEach(d => { %>
          <a href="/listings" style="text-decoration:none; color:inherit;">
            <div style="font-weight:600; font-size:0.9rem;"><%- d.city %></div>
            <div style="color:#717171; font-size:0.85rem;"><%- d.type %></div>
          </a>
        <% }) %>
      </div>
    </div>

    <div id="tab-arts" class="tab-content" style="display:none;">
      <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:1.2rem 1.5rem;">
        <% [
          {city:"Île de Ré",type:"Holiday rentals"},{city:"Paris",type:"Flat rentals"},{city:"Haeundae Beach",type:"Flat rentals"},
          {city:"Cuyahoga Valley",type:"Holiday rentals"},{city:"Times Square",type:"House rentals"},{city:"Jay Peak Resort",type:"Apartment rentals"},
          {city:"Lake Gregory",type:"House rentals"},{city:"Olympic National Park",type:"Flat rentals"},{city:"SoFi Stadium",type:"House rentals"},
          {city:"Flathead Lake",type:"Cabin rentals"},{city:"Playa Venao",type:"Villa rentals"},{city:"Lake Tahoe",type:"Cottage rentals"},
          {city:"Badlands",type:"Holiday rentals"},{city:"Gozo",type:"Villa rentals"},{city:"Lambeau Field",type:"House rentals"},
          {city:"Canal Saint-Martin",type:"Apartment rentals"},{city:"Samara Beach",type:"Holiday rentals"}
        ].forEach(d => { %>
          <a href="/listings" style="text-decoration:none; color:inherit;">
            <div style="font-weight:600; font-size:0.9rem;"><%- d.city %></div>
            <div style="color:#717171; font-size:0.85rem;"><%- d.type %></div>
          </a>
        <% }) %>
      </div>
    </div>

    <div id="tab-beach" class="tab-content" style="display:none;">
      <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:1.2rem 1.5rem;">
        <% [
          {city:"Buyé Beach",type:"Villa rentals"},{city:"El Medano Beach",type:"Holiday rentals"},{city:"Bradley Beach",type:"Holiday rentals"},
          {city:"Bingin Beach",type:"Pet-friendly rentals"},{city:"Bonita Beach",type:"Monthly Rentals"},{city:"Wailea",type:"Apartment rentals"},
          {city:"Armacao dos Buzios",type:"House rentals"},{city:"Maryland Beach",type:"Monthly Rentals"},{city:"Jamaica Beach",type:"Pet-friendly rentals"},
          {city:"Patong Beach",type:"Apartment rentals"},{city:"Galveston Island",type:"Apartment rentals"},{city:"Butler Beach",type:"Monthly Rentals"},
          {city:"Turtle Beach",type:"Monthly Rentals"},{city:"Cabrera",type:"Holiday rentals"},{city:"Zipolite, Oaxaca",type:"House rentals"},
          {city:"Ksamil",type:"Flat rentals"},{city:"El Nido",type:"Holiday rentals"}
        ].forEach(d => { %>
