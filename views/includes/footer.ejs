          {city:"Kanab",type:"Holiday rentals"},{city:"Mammoth Lakes",type:"Flat rentals"}
        ].forEach(d => { %>
          <a href="/listings" style="text-decoration:none; color:inherit;">
            <div style="font-weight:600; font-size:0.9rem;"><%- d.city %></div>
            <div style="color:#717171; font-size:0.85rem;"><%- d.type %></div>
          </a>
        <% }) %>
      </div>
    </div>

    <div id="tab-things" class="tab-content" style="display:none;">
      <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:1.2rem 1.5rem;">
        <% [
          {city:"Durham",type:"Art and culture"},{city:"Apennine Mountains",type:"Entertainment"},{city:"Norfolk",type:"Things to do"},
          {city:"Mexico City",type:"Wellness"},{city:"Seine",type:"Art and culture"},{city:"Paris",type:"Entertainment"},
          {city:"Rome",type:"Nature and outdoors"},{city:"San Juan",type:"Tours"},{city:"Honshu",type:"Wellness"},
          {city:"Plainview",type:"Art and culture"},{city:"Florence",type:"Sightseeing"},{city:"Tokyo",type:"Tours"},
          {city:"Channel Islands",type:"Food and drink"},{city:"7th Arrondissement",type:"Things to do"},{city:"Elgin",type:"Tours"},
          {city:"Medellín River",type:"Art and culture"},{city:"Barcelonès",type:"Sightseeing"}
        ].forEach(d => { %>
          <a href="/listings" style="text-decoration:none; color:inherit;">
            <div style="font-weight:600; font-size:0.9rem;"><%- d.city %></div>
            <div style="color:#717171; font-size:0.85rem;"><%- d.type %></div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Middle: Support / Hosting / SuiteSpot -->
  <div style="padding:3rem 5rem; border-bottom:1px solid #ebebeb; display:grid; grid-template-columns:repeat(3,1fr); gap:2rem;">
    <div>
      <p style="font-weight:700; font-size:1rem; margin:0 0 1.2rem 0;">Support</p>
      <% ["Help Centre","Get help with a safety issue","AirCover","Anti-discrimination","Disability support","Cancellation options","Report neighbourhood concern"].forEach(item => { %>
        <a href="/listings" style="display:block; color:#222; text-decoration:none; margin-bottom:0.7rem; font-size:0.92rem;"><%- item %></a>
      <% }) %>
    </div>
    <div>
      <p style="font-weight:700; font-size:1rem; margin:0 0 1.2rem 0;">Hosting</p>
      <% [
        {label:"Add a listing", href:"/listings/new"},
        {label:"Explore listings", href:"/listings"},
        {label:"Travel Map", href:"/travel-map"},
        {label:"AirCover for Hosts", href:"/listings"},
        {label:"Hosting resources", href:"/listings"},
        {label:"Community forum", href:"/listings"},
        {label:"Hosting responsibly", href:"/listings"},
        {label:"Join a free hosting class", href:"/listings"},
        {label:"Find a co-host", href:"/listings"},
        {label:"Refer a host", href:"/listings"},
      ].forEach(item => { %>
        <a href="<%- item.href %>" style="display:block; color:#222; text-decoration:none; margin-bottom:0.7rem; font-size:0.92rem;"><%- item.label %></a>
      <% }) %>
    </div>
    <div>
      <p style="font-weight:700; font-size:1rem; margin:0 0 1.2rem 0;">SuiteSpot</p>
      <% [
        {label:"2025 Summer Release", href:"/listings"},
        {label:"Newsroom", href:"/listings"},
        {label:"Careers", href:"/listings"},
        {label:"Investors", href:"/listings"},
        {label:"SuiteSpot.org emergency stays", href:"/listings"},
      ].forEach(item => { %>
        <a href="<%- item.href %>" style="display:block; color:#222; text-decoration:none; margin-bottom:0.7rem; font-size:0.92rem;"><%- item.label %></a>
      <% }) %>
    </div>
  </div>

<!-- Bottom bar -->
