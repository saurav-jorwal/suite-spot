            <div style="color:#717171; font-size:0.85rem;"><%- d.type %></div>
          </a>
        <% }) %>
      </div>
    </div>

    <div id="tab-outdoors" class="tab-content" style="display:none;">
      <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:1.2rem 1.5rem;">
        <% [
          {city:"Niagara Falls",type:"Villa rentals"},{city:"Sequim",type:"Beachfront rentals"},{city:"Corvallis",type:"Apartment rentals"},
          {city:"Scottsdale",type:"Villa rentals"},{city:"Uvita",type:"House rentals"},{city:"Juan Dolio",type:"Beachfront rentals"},
          {city:"Highlands",type:"Apartment rentals"},{city:"Key Colony Beach",type:"Flat rentals"},{city:"Squamish",type:"Flat rentals"},
          {city:"Carolina",type:"Flat rentals"},{city:"Banff",type:"Holiday rentals"},{city:"Morro Bay",type:"Flat rentals"},
